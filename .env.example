# ===================================
# CONFIGURATION PORTFOLIO DJANGO
# Copier ce fichier en .env et remplir les valeurs
# ===================================

# SÉCURITÉ
SECRET_KEY=votre-cle-secrete-tres-longue-et-aleatoire
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# BASE DE DONNÉES
# SQLite en local — laisser DATABASE_URL vide
# PostgreSQL en production (Neon) :
DATABASE_URL=postgres://user:password@host/dbname?sslmode=require

# CLOUDINARY (fichiers media en production)
# Créer un compte sur https://cloudinary.com (gratuit)
CLOUDINARY_CLOUD_NAME=votre-cloud-name
CLOUDINARY_API_KEY=votre-api-key
CLOUDINARY_API_SECRET=votre-api-secret

# EMAIL
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
# Pour l'envoi réel (Gmail) :
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=votre@gmail.com
EMAIL_HOST_PASSWORD=votre_app_password_gmail
DEFAULT_FROM_EMAIL=noreply@portfolio.com

# CORS (production — mettre l'URL Vercel)
CORS_ALLOWED_ORIGINS=http://localhost:8000
