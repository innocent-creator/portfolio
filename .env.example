# ===================================
# CONFIGURATION PORTFOLIO DJANGO
# Copier ce fichier en .env et remplir les valeurs
# ===================================

# SÉCURITÉ
SECRET_KEY=votre-cle-secrete-tres-longue-et-aleatoire
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# BASE DE DONNÉES (SQLite par défaut — laisser vide)
DB_ENGINE=django.db.backends.sqlite3
DB_NAME=db.sqlite3
# Pour PostgreSQL en production :
# DB_ENGINE=django.db.backends.postgresql
# DB_NAME=portfolio_db
# DB_USER=postgres
# DB_PASSWORD=votre_mot_de_passe
# DB_HOST=localhost
# DB_PORT=5432

# EMAIL
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
# Pour l'envoi réel (Gmail) :
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=votre@gmail.com
EMAIL_HOST_PASSWORD=votre_app_password_gmail
DEFAULT_FROM_EMAIL=noreply@portfolio.com

# CORS (production)
CORS_ALLOWED_ORIGINS=http://localhost:8000
